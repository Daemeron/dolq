{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.daemeron.dolq",
  "productName": "Dolq",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "out/**"
  ],
  "publish": null,
  "mac": {
    "sign": {
      "identity": "-",
      "hardenedRuntime": false
    },
    "target": [
      "dmg",
      "zip"
    ]
  },
  "win": {
    "executableName": "dolq",
    "target": [
      "nsis"
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Network"
  }
}